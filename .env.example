# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://siphon:siphon@postgres:5432/siphon
POSTGRES_PASSWORD=siphon

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SIPHON_JWT_SECRET=REPLACE_ME_minimum_32_random_characters

# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SIPHON_ENCRYPTION_KEY=REPLACE_ME_run_python_-c_"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Bootstrap admin (used only when no users exist in the database) ───────────
SIPHON_ADMIN_EMAIL=admin@example.com
SIPHON_ADMIN_PASSWORD=changeme123

# ── Redis (Celery broker/backend) ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Worker ────────────────────────────────────────────────────────────────────
SIPHON_MAX_WORKERS=4
SIPHON_PORT=8000

# ── S3 / Parquet destination ──────────────────────────────────────────────────
SIPHON_ALLOWED_S3_PREFIX=bronze/
SIPHON_S3_SCHEME=http
# S3_ENDPOINT_URL=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_DEFAULT_REGION=us-east-1

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=siphon

# ── Feature flags ─────────────────────────────────────────────────────────────
# SIPHON_ENABLE_SYNC_EXTRACT=true   # enables POST /extract (disabled by default)
# SIPHON_JOB_TTL_SECONDS=3600       # how long finished jobs stay in memory
# SIPHON_MAX_FILE_SIZE_MB=500       # max SFTP file size
